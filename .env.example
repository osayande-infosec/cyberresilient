# ── CyberResilient Environment Configuration ──────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# AWS Deployment (optional — only needed for ECS deployment)
AWS_REGION=ca-central-1
AWS_ACCOUNT_ID=
ECR_REPO=cyberresilient
ECS_CLUSTER=cyberresilient-cluster
ECS_SERVICE=cyberresilient-service

# Streamlit
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Organization Profile (see config/org_profile.yaml)
# ORG_PROFILE=config/org_profile.yaml

# Database (default: SQLite at instance/cyberresilient.db)
# DATABASE_URL=sqlite:///instance/cyberresilient.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/cyberresilient

# Authentication (set to "true" to enable login/RBAC)
# CYBERRESILIENT_AUTH=false
